# Copy this file to ".env" and fill in values if you want to enable
# real Azure AI Vision / Azure AI Language integration later.
# The project works completely fine without any of these.

SECRET_KEY=change-this-to-something-random

# Network configuration for public access
# APP_HOST=0.0.0.0 makes the app accessible from any network interface
# APP_PORT=5000 is the port the app listens on
# Leave these commented out to use defaults (0.0.0.0:5000)
# APP_HOST=0.0.0.0
# APP_PORT=5000

AZURE_VISION_KEY=
AZURE_VISION_ENDPOINT=

AZURE_LANGUAGE_KEY=
AZURE_LANGUAGE_ENDPOINT=
